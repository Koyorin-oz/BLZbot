{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": "node .cursor/hooks/git-stage-on-edit.js",
        "matcher": "Write|TabWrite",
        "timeout": 30
      }
    ],
    "stop": [
      {
        "command": "node .cursor/hooks/git-commit-push-on-stop.js",
        "timeout": 180
      }
    ]
  }
}
