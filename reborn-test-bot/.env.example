# Copie ce fichier en .env à côté (même dossier reborn-test-bot/)
# Le programme charge : reborn-test-bot/.env

# Portail Discord → application de TEST → Bot → token (sans guillemets, une seule ligne)
REBORN_TEST_BOT_TOKEN=

# Portail Discord → application de TEST → nom en haut : « ID de l'application »
# (bot de test actuel — avril 2026)
REBORN_TEST_BOT_CLIENT_ID=1498205315907453038

# Discord → Paramètres → Avancés → « Mode développeur » ON
# Clic droit sur le SERVEUR de test → Copier l'identifiant du serveur
REBORN_TEST_GUILD_ID=1493276404643532810

# Optionnel : IDs Discord (séparés par des virgules) pour les commandes owner si besoin
REBORN_TEST_OWNER_IDS=

# 1 (défaut) = enregistrer les slash commands à chaque démarrage du bot. 0 = désactiver.
REBORN_AUTO_DEPLOY_SLASH=1

# Rôle Discord autorisant /hacker (ID du rôle). Vide = tout le monde (sandbox). Owners toujours OK.
REBORN_HACKER_ROLE_ID=

# 1 (défaut) = déployer aussi les slash du dossier niveau (bot principal) sur cette appli ; 0 = uniquement les commandes reborn-test-bot.
REBORN_MIRROR_NIVEAU_SLASH=1

# 1 (défaut) = exécuter le vrai code des commandes « niveau » (BDD / canvas = même stack que BLZbot, dépendances à la racine du repo). 0 = message « utiliser BLZbot » (stub).
REBORN_MIRROR_NIVEAU_EXECUTE=1
