# Token du bot (Application Discord dédiée « test », pas celle de BLZbot)
REBORN_TEST_BOT_TOKEN=

# ID de l'application (Client ID) — obligatoire pour déployer les slash commands
REBORN_TEST_BOT_CLIENT_ID=

# Optionnel : ID d'un serveur de test → enregistrement instantané des commandes (guild)
# Laisser vide pour enregistrement global (peut prendre jusqu’à ~1 h)
REBORN_TEST_GUILD_ID=

# Optionnel : IDs Discord autorisés pour les commandes « owner » (séparés par des virgules)
# Si vide, seul le propriétaire de l’application Discord est considéré comme owner
REBORN_TEST_OWNER_IDS=
