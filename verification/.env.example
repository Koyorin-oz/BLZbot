# =============================================================================
# Bot de vérification BLZ — variables d'environnement
# =============================================================================
# Ces variables peuvent vivre soit dans `verification/.env` (standalone),
# soit dans le `.env` partagé avec les autres bots BLZ (racine du repo ou
# `/home/container/.env` sur Pebble Host).
#
# Convention : pour les variables qui pourraient entrer en conflit avec le bot
# modération (BOT_TOKEN, DISCORD_CLIENT_ID, DISCORD_CLIENT_SECRET), on utilise
# des noms préfixés `VERIFICATION_*` pour cohabiter dans le même .env sans
# écraser les valeurs du bot modération.
# =============================================================================

# ─── Discord (obligatoire) ───────────────────────────────────────────────────
# Token du bot dédié à la vérification.
# ⚠️  C'est un bot DIFFÉRENT du bot modération — crée une nouvelle application
#     Discord, sinon tu vas écraser le token de la modération.
VERIFICATION_BOT_TOKEN=

# Application ID de cette même app (Portail dev → General Information → Application ID)
VERIFICATION_CLIENT_ID=

# Client Secret OAuth2 de cette même app (Portail dev → OAuth2 → Reset Secret)
# ⚠️  Garde-le ULTRA secret — équivalent d'un mot de passe pour OAuth.
VERIFICATION_CLIENT_SECRET=

# Redirect URI configurée dans le portail (OAuth2 → Redirects).
# Doit correspondre EXACTEMENT à ce qui est configuré côté Discord.
#   Local      : http://localhost:3782/oauth/callback
#   Cloudflare : https://verify.tonsite.com/oauth/callback
#   IP+port    : http://145.239.X.X:3782/oauth/callback   (déconseillé)
OAUTH_REDIRECT_URI=

# URL publique du serveur (sans / final). Doit être joignable par les membres
# (pour les liens dans Discord et la redirection OAuth).
#   Local      : http://localhost:3782
#   Cloudflare : https://verify.tonsite.com
PUBLIC_BASE_URL=

# Port HTTP du serveur OAuth (défaut 3782).
HTTP_PORT=3782

# Interface d'écoute du serveur HTTP.
#   0.0.0.0   → accessible depuis l'extérieur (à protéger via VERIFY_PROXY_SECRET)
#   127.0.0.1 → accessible UNIQUEMENT depuis la même machine (recommandé si proxy local)
HTTP_HOST=0.0.0.0

# Secret pour signer le state OAuth (HMAC, ≥ 32 caractères).
# Génère avec : node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
OAUTH_STATE_SECRET=

# ─── Owners qui reçoivent les logs IP + Email en DM ──────────────────────────
# IDs Discord séparés par virgule. Les logs SANS IP/email vont dans le salon
# configuré par /setup-verification ; les logs AVEC IP+email vont en DM à ces
# utilisateurs. Si vide, les logs sensibles ne partent à PERSONNE.
OWNER_DM_IDS=965984018216665099,1278372257483456603

# ─── Anti-raid (BLZbot-protect — optionnel, défauts dans verification/src/antiraid/config.js) ─
# Active l’intent « Message Content » sur l’app Discord du bot protect.
# ANTI_RAID_ROLE_ID=
# ANTI_RAID_LOG_CHANNEL_ID=
# ANTI_RAID_ALL_LOG_CHANNEL_ID=
# ANTI_RAID_PROTECTED_ROLES=id1,id2
# ANTI_RAID_DB_PATH=modération/raid_incidents.db   # une fois : réutiliser l’ancienne DB SQLite

# =============================================================================
# Reverse proxy (optionnel — recommandé pour cacher l'IP du serveur)
# =============================================================================
# Voir README.md section "Reverse proxy" pour le setup complet.
#
# Si tu utilises un reverse proxy (Cloudflare Tunnel, Caddy, nginx) qui forward
# vers ce bot, DÉFINIS un secret partagé. Le bot rejettera (403 Forbidden)
# toute requête qui ne contient pas le header X-Verif-Proxy-Secret avec cette
# valeur. Le proxy doit être configuré pour injecter ce header.
#
# Génère avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VERIFY_PROXY_SECRET=

# Alternative au secret : whitelist d'IPs sources autorisées à hit le bot.
# Sépare par virgule. Si VERIFY_PROXY_SECRET est défini, ce paramètre est ignoré.
#   Exemple : VERIFY_PROXY_IPS=1.2.3.4,5.6.7.8
VERIFY_PROXY_IPS=

# =============================================================================
# COMPATIBILITÉ — anciens noms (sans préfixe VERIFICATION_)
# =============================================================================
# Si tu utilises un .env STANDALONE (uniquement pour le bot vérif, pas partagé
# avec le bot modération), tu peux à la place utiliser ces noms historiques.
# Le bot vérif les lit en fallback si les `VERIFICATION_*` ne sont pas définies.
#
# BOT_TOKEN=...
# DISCORD_CLIENT_ID=...
# DISCORD_CLIENT_SECRET=...
#
# ⚠️  N'utilise CES noms QUE si tu as un .env dédié au bot vérif. Sinon tu
#     écraseras les valeurs du bot modération.
