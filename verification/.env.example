# =============================================================================
# Bot de vérification BLZ — variables d'environnement
# =============================================================================
# Copie ce fichier en `.env` (dans le même dossier verification/) et remplis-le.
# .env n'est PAS commit (voir .gitignore).
# =============================================================================

# --- Discord (obligatoire) ---
# Token du bot Discord (Portail dev → Bot → Reset Token)
BOT_TOKEN=

# Application ID (Portail dev → General Information → Application ID)
DISCORD_CLIENT_ID=

# Client Secret (Portail dev → OAuth2 → Client Secret)
DISCORD_CLIENT_SECRET=

# Redirect URI configurée dans le portail (OAuth2 → Redirects)
# Doit correspondre EXACTEMENT à ce qui est configuré côté Discord.
# Ex local : http://localhost:3782/oauth/callback
# Ex prod  : https://verif.tondomaine.com/oauth/callback
OAUTH_REDIRECT_URI=

# URL publique du serveur (sans / final). Doit être joignable par les membres
# (pour les liens dans Discord et la redirection OAuth).
# En local : http://localhost:3782
# En prod  : https://verif.tondomaine.com
PUBLIC_BASE_URL=

# Port HTTP du serveur OAuth (défaut 3782)
HTTP_PORT=3782

# Secret pour signer le state OAuth (généré aléatoirement, ≥ 32 caractères).
# Tu peux générer avec : node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
OAUTH_STATE_SECRET=

# --- Owners qui reçoivent les logs IP en DM (obligatoire) ---
# IDs Discord séparés par virgule. Les logs SANS IP vont dans le salon configuré
# par /setup-verification ; les logs AVEC IP vont en DM à ces utilisateurs.
OWNER_DM_IDS=965984018216665099,1278372257483456603
